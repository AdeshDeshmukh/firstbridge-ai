# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_supabase_pooler_url_port_6543
DIRECT_DATABASE_URL=your_supabase_direct_url_port_5432

# ── BACKBOARD ─────────────────────────────────────────────
BACKBOARD_API_KEY=your_backboard_api_key
BACKBOARD_VERA_AGENT_ID=your_vera_agent_id
BACKBOARD_GRANT_AGENT_ID=your_grant_agent_id
BACKBOARD_ATLAS_AGENT_ID=your_atlas_agent_id

# ── ASSEMBLYAI ────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ── YOUCAM (PERFECT CORP) ─────────────────────────────────
YOUCAM_API_KEY=your_youcam_key
YOUCAM_API_ENDPOINT=your_youcam_endpoint

# ── STRIPE ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_STARTER_PRICE_ID=price_your_starter_id
STRIPE_GROWTH_PRICE_ID=price_your_growth_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ── CLOUDFLARE R2 ─────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=firstbridge-media
R2_PUBLIC_URL=https://your_bucket.your_account.r2.cloudflarestorage.com

# ── SENDGRID ──────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_key
SENDGRID_FROM_EMAIL=noreply@firstbridge.ai

# ── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── SENTRY ────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ── APP ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000